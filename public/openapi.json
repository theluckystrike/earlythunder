      "description": "Payment required (authoritative challenge)"
     }
    },
    "x-payment-info": {
     "offers": [
      {
       "method": "x402",
       "network": "eip155:8453",
       "asset": "USDC",
       "advisoryPriceUsd": 0.25
      },
      {
       "method": "x402",
       "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
       "asset": "USDC",
       "advisoryPriceUsd": 0.25
      }
     ]
    },
    "parameters": [
     {
      "name": "slug",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      },
      "description": "Asset slug from /api/x402/v1/scores, e.g. ethereum"
     }
    ]
   }
  },
